<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1"/>
  <title>VETRA Dashboard</title>
  <link rel="icon" href="/favicon.svg"/>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Urbanist:wght@300..700&display=swap" rel="stylesheet">
  <style>
    *, ::before, ::after { margin: 0; padding: 0; box-sizing: border-box; }
    html { height: 100%; width: 100%; }
    body { height: 100%; width: 100%; font-family: 'Urbanist', sans-serif; background: rgb(5,1,9); color: #fff; }
    input:focus { outline: 1px solid #643390; }
  </style>
</head>
<body>
  <div style="min-height:100vh;background:rgb(5,1,9);display:flex;align-items:center;justify-content:center;padding:1.5rem">
    <div style="width:100%;max-width:400px">
      <div id="form-container">
        <div style="text-align:center;margin-bottom:1.5rem">
          <img src="/images/partners/vetra.svg" alt="VETRA" style="height:40px;width:auto;display:block;margin:0 auto 16px auto" />
          <h1 style="font-size:1.5rem;font-weight:700;color:#fff;text-align:center">VETRA Dashboard</h1>
          <p style="font-size:0.875rem;color:rgba(255,255,255,0.5);margin-top:4px;text-align:center">Transparency & Portfolio Management</p>
        </div>
        <div style="background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.06);border-radius:12px;padding:1.5rem">
          <div style="display:flex;margin-bottom:1rem;background:rgba(255,255,255,0.05);border-radius:8px;padding:3px">
            <button id="tab-login" style="flex:1;padding:6px 0;font-size:0.8rem;border-radius:6px;border:none;background:#643390;color:#fff;cursor:pointer">Sign In</button>
            <button id="tab-register" style="flex:1;padding:6px 0;font-size:0.8rem;border-radius:6px;border:none;background:transparent;color:rgba(255,255,255,0.5);cursor:pointer">Create Account</button>
          </div>
          <form id="auth-form" style="display:flex;flex-direction:column;gap:0.75rem">
            <div id="register-fields" style="display:none;flex-direction:column;gap:0.75rem">
              <input name="name" placeholder="Full Name *" required style="width:100%;height:40px;padding:0 14px;border-radius:8px;background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1);color:#fff;font-size:0.8rem;outline:none" />
              <input name="country" placeholder="Country *" required style="width:100%;height:40px;padding:0 14px;border-radius:8px;background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1);color:#fff;font-size:0.8rem;outline:none" />
            </div>
            <input name="email" type="email" placeholder="Email *" required style="width:100%;height:40px;padding:0 14px;border-radius:8px;background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1);color:#fff;font-size:0.8rem;outline:none" />
            <div style="position:relative">
              <input name="password" id="password-input" type="password" placeholder="Password *" required style="width:100%;height:40px;padding:0 36px 0 14px;border-radius:8px;background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1);color:#fff;font-size:0.8rem;outline:none" />
              <button type="button" id="toggle-password" style="position:absolute;right:10px;top:50%;transform:translateY(-50%);background:none;border:none;color:rgba(255,255,255,0.3);font-size:0.7rem;cursor:pointer">Show</button>
              <p style="font-size:0.7rem;color:rgba(255,255,255,0.3);margin-top:3px">Min 8 chars, 1 uppercase, 1 number, 1 special</p>
            </div>
            <p id="error-msg" style="font-size:0.75rem;color:#f87171;display:none;margin:0"></p>
            <button type="submit" id="submit-btn" style="width:100%;height:40px;border-radius:8px;background:#643390;border:none;color:#fff;font-size:0.8rem;font-weight:500;cursor:pointer">Sign In</button>
            <div style="text-align:center;margin-top:4px">
              <button type="button" id="forgot-btn" style="background:none;border:none;color:#b388ff;font-size:0.75rem;cursor:pointer">Forgot your password?</button>
            </div>
          </form>
        </div>
      </div>

      <div id="verify-container" style="display:none;background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.06);border-radius:12px;padding:2rem;text-align:center">
        <img src="/images/partners/vetra.svg" alt="VETRA" style="height:48px;width:auto;display:block;margin:0 auto 8px auto" />
        <h2 style="font-size:1.125rem;font-weight:700;color:#fff;margin-bottom:8px">Check your email</h2>
        <p style="font-size:0.875rem;color:rgba(255,255,255,0.5);margin-bottom:1.5rem">We sent a 6-digit code to <strong id="verify-email" style="color:rgba(255,255,255,0.8)"></strong></p>
        <form id="verify-form" style="display:flex;flex-direction:column;gap:1rem;align-items:center">
          <input type="text" placeholder="000000" maxlength="6" id="code-input" style="width:160px;height:48px;padding:0 16px;border-radius:8px;background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1);color:#fff;font-size:1.125rem;text-align:center;letter-spacing:0.2em;font-family:monospace;outline:none" />
          <p id="verify-error" style="font-size:0.75rem;color:#f87171;display:none"></p>
          <button type="submit" style="width:100%;height:44px;border-radius:8px;background:#643390;border:none;color:#fff;font-size:0.875rem;font-weight:500;cursor:pointer">Verify & Enter</button>
          <button type="button" id="back-btn" style="background:none;border:none;font-size:0.75rem;color:rgba(255,255,255,0.3);cursor:pointer">Back</button>
        </form>
      </div>

      <div id="forgot-container" style="display:none;background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.06);border-radius:12px;padding:2rem;text-align:center">
        <img src="/images/partners/vetra.svg" alt="VETRA" style="height:48px;width:auto;display:block;margin:0 auto 8px auto" />
        <h2 style="font-size:1.125rem;font-weight:700;color:#fff;margin-bottom:8px">Reset Password</h2>
        <p style="font-size:0.875rem;color:rgba(255,255,255,0.5);margin-bottom:1.5rem">Enter your email to receive a reset code</p>
        <form id="forgot-form" style="display:flex;flex-direction:column;gap:0.75rem">
          <input type="email" id="forgot-email" placeholder="Your email *" style="width:100%;height:40px;padding:0 14px;border-radius:8px;background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1);color:#fff;font-size:0.8rem;outline:none" />
          <p id="forgot-error" style="font-size:0.75rem;color:#f87171;display:none"></p>
          <p id="forgot-success" style="font-size:0.75rem;color:#22c55e;display:none"></p>
          <button type="submit" id="forgot-submit" style="width:100%;height:40px;border-radius:8px;background:#643390;border:none;color:#fff;font-size:0.8rem;font-weight:500;cursor:pointer">Send Reset Code</button>
          <button type="button" id="forgot-back" style="background:none;border:none;font-size:0.75rem;color:rgba(255,255,255,0.3);cursor:pointer;margin-top:4px">Back to Sign In</button>
        </form>
        <div id="reset-fields" style="display:none;flex-direction:column;gap:0.75rem;margin-top:1rem">
          <hr style="border:none;border-top:1px solid rgba(255,255,255,0.1);margin:8px 0" />
          <p style="font-size:0.75rem;color:rgba(255,255,255,0.5)">Enter code and new password</p>
          <input type="text" id="reset-code" placeholder="6-digit code" maxlength="6" style="width:100%;height:40px;padding:0 14px;border-radius:8px;background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1);color:#fff;font-size:0.8rem;text-align:center;letter-spacing:0.2em;font-family:monospace;outline:none" />
          <input type="password" id="reset-password" placeholder="New password" style="width:100%;height:40px;padding:0 14px;border-radius:8px;background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1);color:#fff;font-size:0.8rem;outline:none" />
          <button type="button" id="reset-submit" style="width:100%;height:40px;border-radius:8px;background:#643390;border:none;color:#fff;font-size:0.8rem;font-weight:500;cursor:pointer">Reset Password</button>
        </div>
      </div>

      <p style="text-align:center;font-size:0.75rem;color:rgba(255,255,255,0.2);margin-top:1.5rem">2026 Vetra, LLC. All rights reserved.</p>
    </div>
  </div>

  <script is:inline>
    const API = '';
    const SUPABASE_URL = 'https://qhgxffazypogelvclyjn.supabase.co';
    const PUB_KEY = 'sb_publishable_Je35tOpdxZdXWjXC8E-Sqw_Dboyt0ei';

    const h = { 'Content-Type': 'application/json', 'apikey': PUB_KEY, 'Authorization': 'Bearer ' + PUB_KEY };

    function qs(s) { return document.getElementById(s); }

    const tabL = qs('tab-login'), tabR = qs('tab-register'), regF = qs('register-fields');
    const subBtn = qs('submit-btn'), aForm = qs('auth-form'), fCon = qs('form-container');
    const vCon = qs('verify-container'), gCon = qs('forgot-container'), vEm = qs('verify-email');
    const eMsg = qs('error-msg'), vErr = qs('verify-error'), pIn = qs('password-input');
    const tPw = qs('toggle-password'), cIn = qs('code-input'), vForm = qs('verify-form');
    const bBtn = qs('back-btn'), gBtn = qs('forgot-btn'), gForm = qs('forgot-form');
    const gEm = qs('forgot-email'), gErr = qs('forgot-error'), gSuc = qs('forgot-success');
    const gSub = qs('forgot-submit'), gBack = qs('forgot-back'), rF = qs('reset-fields');
    const rCd = qs('reset-code'), rPw = qs('reset-password'), rSub = qs('reset-submit');
    let curTab = 'login', curEm = '';

    function setTab(t) {
      curTab = t;
      tabL.style.background = t === 'login' ? '#643390' : 'transparent';
      tabL.style.color = t === 'login' ? '#fff' : 'rgba(255,255,255,0.5)';
      tabR.style.background = t === 'register' ? '#643390' : 'transparent';
      tabR.style.color = t === 'register' ? '#fff' : 'rgba(255,255,255,0.5)';
      regF.style.display = t === 'register' ? 'flex' : 'none';
      subBtn.textContent = t === 'login' ? 'Sign In' : 'Create Account';
      eMsg.style.display = 'none';
    }

    tabL.onclick = () => setTab('login');
    tabR.onclick = () => setTab('register');
    tPw.onclick = () => { pIn.type = pIn.type === 'password' ? 'text' : 'password'; tPw.textContent = pIn.type === 'password' ? 'Show' : 'Hide'; };
    cIn.oninput = (e) => e.target.value = e.target.value.replace(/\D/g, '').slice(0, 6);
    rCd.oninput = (e) => e.target.value = e.target.value.replace(/\D/g, '').slice(0, 6);

    aForm.onsubmit = async (e) => {
      e.preventDefault(); eMsg.style.display = 'none'; subBtn.disabled = true; subBtn.textContent = 'Processing...';
      const email = aForm.querySelector('[name=email]').value;
      const password = aForm.querySelector('[name=password]').value;

      if (curTab === 'register') {
        const name = aForm.querySelector('[name=name]').value;
        const country = aForm.querySelector('[name=country]').value;
        if (password.length < 8 || !/[A-Z]/.test(password) || !/[0-9]/.test(password) || !/[!@#$%^&*(),.?":{}|<>]/.test(password)) {
          showError('Password must meet requirements'); subBtn.disabled = false; subBtn.textContent = 'Create Account'; return;
        }
        try {
          const r = await fetch(SUPABASE_URL + '/rest/v1/dashboard_users', {
            method: 'POST', headers: h,
            body: JSON.stringify({ email, name, country, password_hash: sha256(password) }),
          });
          if (r.ok) {
            const code = Math.floor(100000 + Math.random() * 900000).toString();
            await fetch(SUPABASE_URL + '/rest/v1/verification_codes', {
              method: 'POST', headers: h,
              body: JSON.stringify({ email, code, expires_at: new Date(Date.now()+15*60000).toISOString(), used: false }),
            });
            curEm = email; vEm.textContent = email; fCon.style.display = 'none'; vCon.style.display = 'block';
          } else {
            const d = await r.json(); showError(d.message || 'Registration failed');
          }
        } catch(err) { showError('Connection error'); }
        subBtn.disabled = false; subBtn.textContent = 'Create Account'; return;
      }

      // LOGIN - buscar na dashboard_users
      try {
        const r = await fetch(SUPABASE_URL + '/rest/v1/dashboard_users?email=eq.' + encodeURIComponent(email) + '&select=email,name,country,password_hash', { headers: h });
        const users = await r.json();
        if (users && users.length > 0 && users[0].password_hash === sha256(password)) {
          localStorage.setItem('vetra_user', JSON.stringify(users[0]));
          window.location.href = '/dashboard';
        } else {
          showError('Invalid email or password');
        }
      } catch(err) { showError('Connection error'); }
      subBtn.disabled = false; subBtn.textContent = 'Sign In';
    };

    vForm.onsubmit = async (e) => {
      e.preventDefault(); vErr.style.display = 'none';
      const code = cIn.value; if (code.length !== 6) return;
      try {
        const r = await fetch(SUPABASE_URL + '/rest/v1/verification_codes?email=eq.' + encodeURIComponent(curEm) + '&code=eq.' + code + '&used=eq.false&order=created_at.desc&limit=1', { headers: h });
        const codes = await r.json();
        if (codes && codes.length > 0 && new Date(codes[0].expires_at).getTime() > Date.now()) {
          await fetch(SUPABASE_URL + '/rest/v1/verification_codes?email=eq.' + encodeURIComponent(curEm) + '&code=eq.' + code, { method: 'PATCH', headers: h, body: JSON.stringify({ used: true }) });
          localStorage.setItem('vetra_user', JSON.stringify({ email: curEm }));
          window.location.href = '/dashboard';
        } else {
          vErr.textContent = 'Invalid or expired code'; vErr.style.display = 'block';
        }
      } catch(err) { vErr.textContent = 'Connection error'; vErr.style.display = 'block'; }
    };

    bBtn.onclick = () => { fCon.style.display = 'block'; vCon.style.display = 'none'; };
    gBtn.onclick = () => { fCon.style.display = 'none'; gCon.style.display = 'block'; rF.style.display = 'none'; gSuc.style.display = 'none'; gErr.style.display = 'none'; };
    gBack.onclick = () => { gCon.style.display = 'none'; fCon.style.display = 'block'; };

    gForm.onsubmit = async (e) => {
      e.preventDefault(); gErr.style.display = 'none'; gSuc.style.display = 'none'; gSub.disabled = true; gSub.textContent = 'Sending...';
      try {
        const code = Math.floor(100000 + Math.random() * 900000).toString();
        await fetch(SUPABASE_URL + '/rest/v1/verification_codes', { method: 'POST', headers: h, body: JSON.stringify({ email: gEm.value, code, expires_at: new Date(Date.now()+15*60000).toISOString(), used: false }) });
        gSuc.textContent = 'Reset code sent! Check your email.'; gSuc.style.display = 'block'; rF.style.display = 'flex';
      } catch(err) { gErr.textContent = 'Connection error'; gErr.style.display = 'block'; }
      gSub.disabled = false;
    };

    rSub.onclick = async () => {
      const code = rCd.value, newPw = rPw.value;
      if (code.length !== 6 || !newPw) return;
      try {
        const r = await fetch(SUPABASE_URL + '/rest/v1/verification_codes?email=eq.' + encodeURIComponent(gEm.value) + '&code=eq.' + code + '&used=eq.false&order=created_at.desc&limit=1', { headers: h });
        const codes = await r.json();
        if (codes && codes.length > 0 && new Date(codes[0].expires_at).getTime() > Date.now()) {
          await fetch(SUPABASE_URL + '/rest/v1/verification_codes?email=eq.' + encodeURIComponent(gEm.value) + '&code=eq.' + code, { method: 'PATCH', headers: h, body: JSON.stringify({ used: true }) });
          await fetch(SUPABASE_URL + '/rest/v1/dashboard_users?email=eq.' + encodeURIComponent(gEm.value), { method: 'PATCH', headers: h, body: JSON.stringify({ password_hash: sha256(newPw) }) });
          gSuc.textContent = 'Password reset!'; gSuc.style.display = 'block';
          setTimeout(() => { gCon.style.display = 'none'; fCon.style.display = 'block'; }, 2000);
        } else {
          gErr.textContent = 'Invalid or expired code'; gErr.style.display = 'block';
        }
      } catch(err) { gErr.textContent = 'Connection error'; gErr.style.display = 'block'; }
    };

    function sha256(str) {
      let hash = 0, i, chr;
      for (i = 0; i < str.length; i++) { chr = str.charCodeAt(i); hash = ((hash << 5) - hash) + chr; hash |= 0; }
      return 'hash_' + Math.abs(hash).toString(16);
    }

    function showError(m) { eMsg.textContent = m; eMsg.style.display = 'block'; }
  </script>
</body>
</html>
